# PostgreSQL — use the internal Coolify connection string
DATABASE_URL=postgresql://user:password@host:5432/soberano

# JWT — generate two different long random strings
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# Your production domain
BASE_URL=https://soberano.altion.com.br

# Chatwoot (optional — notifications are skipped if empty)
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
